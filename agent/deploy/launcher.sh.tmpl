#!/usr/bin/env bash
# Lemma Agent — bare-metal launcher.
#
# Generated by `lemma agent install --shape launcher --output <dir>`.
# Run directly:
#
#   ./lemma-agent.sh
#
# Override any value at invocation time:
#
#   HEALTH_PORT=9090 ./lemma-agent.sh
set -euo pipefail

BINARY_PATH="${BINARY_PATH:-{{BINARY_PATH}}}"
EVIDENCE_DIR="${EVIDENCE_DIR:-{{EVIDENCE_DIR}}}"
KEYS_DIR="${KEYS_DIR:-{{KEYS_DIR}}}"
HEALTH_PORT="${HEALTH_PORT:-{{HEALTH_PORT}}}"

if [ ! -x "$BINARY_PATH" ]; then
  echo "lemma-agent binary not found or not executable at $BINARY_PATH" >&2
  exit 1
fi

mkdir -p "$EVIDENCE_DIR"

exec "$BINARY_PATH" serve \
  --port="$HEALTH_PORT" \
  --evidence-dir="$EVIDENCE_DIR" \
  --keys-dir="$KEYS_DIR"
